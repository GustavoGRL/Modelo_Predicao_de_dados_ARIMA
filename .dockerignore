# Docker ignore file

# Ambiente virtual
.env
.venv
venv/
ENV/
env.bak/
venv.bak/

# Cache Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Build e distribuição
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Testes
tests/
test/
.coverage
.pytest_cache/

# Arquivos de desenvolvimento Docker
Dockerfile
docker-compose.yml
.dockerignore
run-docker.sh
run-docker.ps1
DOCKER.md

# Arquivos temporários
*.tmp
*.temp
*.bak

# Arquivos de configuração local
config.local.*
*.local.yaml
*.local.yml

# Diretório de saída (será montado como volume)
# Não ignore completamente, apenas ignore conteúdo existente localmente
output/*
!output/.gitkeep

# Git
.git/
.gitignore